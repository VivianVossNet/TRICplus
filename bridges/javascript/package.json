{
  "name": "tric",
  "version": "0.0.0",
  "description": "TRIC+ Permutive Database Engine — JavaScript and TypeScript client bridge",
  "author": "Vivian Voss",
  "license": "BSD-3-Clause",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/tests/bridge.test.js",
    "fmt": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "fmt:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "unix-dgram": "^2.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
